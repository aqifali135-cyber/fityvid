PORT=8787
VIDEO_EXTRACTOR=yt-dlp
NODE_ENV=development

# FFmpeg required for Instagram audio merge (not on most shared hosting)
# Host backend on Render, Railway, or a VPS with FFmpeg installed
FFMPEG_PATH=ffmpeg
TEMP_DIR=

# Optional: extra yt-dlp flags (space-separated)
# YTDLP_EXTRA_ARGS=

# Optional: Netscape cookies file for YouTube when datacenter IPs are blocked
# YOUTUBE_COOKIES_FILE=/path/to/youtube_cookies.txt

# Frontend on Vercel: set VITE_API_BASE_URL to your backend URL
