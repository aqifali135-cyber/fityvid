PORT=8787
NODE_ENV=development

# Video provider: rapidapi_all_in_one (production/cPanel) or yt-dlp (local VPS)
VIDEO_API_PROVIDER=rapidapi_all_in_one

# RapidAPI — Social Download All In One
RAPIDAPI_KEY=
RAPIDAPI_ALL_HOST=social-download-all-in-one.p.rapidapi.com
RAPIDAPI_ALL_BASE_URL=https://social-download-all-in-one.p.rapidapi.com

# Dedicated TikTok Video Downloader (POST /api/tiktok/video-download)
# RapidAPI: TikTok Downloader — Download TikTok Videos without watermark
# Keep credentials backend-only — never expose to the frontend.
RAPIDAPI_TIKTOK_KEY=
RAPIDAPI_TIKTOK_HOST=tiktok-downloader-download-tiktok-videos-without-watermark.p.rapidapi.com

# Optional yt-dlp fallback for local/VPS development
VIDEO_EXTRACTOR=yt-dlp

# FFmpeg only needed when VIDEO_API_PROVIDER=yt-dlp and downloading Instagram with merge
FFMPEG_PATH=ffmpeg
TEMP_DIR=

# Optional yt-dlp flags (yt-dlp provider only)
# YTDLP_EXTRA_ARGS=
# YOUTUBE_COOKIES_FILE=/path/to/youtube_cookies.txt

# Frontend on Vercel: set VITE_API_BASE_URL to your backend URL

# MySQL auth database (Namecheap cPanel)
DB_HOST=localhost
DB_NAME=fitypbvk_fityvid_auth
DB_USER=fitypbvk_fityvid_user
DB_PASSWORD=

# Auth — set a strong secret in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Google OAuth (same client ID as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Frontend URL (used for Lemon Squeezy success/cancel redirects)
FRONTEND_URL=http://localhost:5173

# Lemon Squeezy payments
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMON_STARTER_VARIANT_ID=
LEMON_CREATOR_VARIANT_ID=
LEMON_GROWTH_VARIANT_ID=
LEMON_BUSINESS_VARIANT_ID=
