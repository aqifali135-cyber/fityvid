PORT=8787
NODE_ENV=development

# Video provider: rapidapi_all_in_one (production/cPanel) or yt-dlp (local VPS)
VIDEO_API_PROVIDER=rapidapi_all_in_one

# RapidAPI — Social Download All In One
RAPIDAPI_KEY=
RAPIDAPI_ALL_HOST=social-download-all-in-one.p.rapidapi.com
RAPIDAPI_ALL_BASE_URL=https://social-download-all-in-one.p.rapidapi.com

# Optional yt-dlp fallback for local/VPS development
VIDEO_EXTRACTOR=yt-dlp

# FFmpeg only needed when VIDEO_API_PROVIDER=yt-dlp and downloading Instagram with merge
FFMPEG_PATH=ffmpeg
TEMP_DIR=

# Optional yt-dlp flags (yt-dlp provider only)
# YTDLP_EXTRA_ARGS=
# YOUTUBE_COOKIES_FILE=/path/to/youtube_cookies.txt

# Frontend on Vercel: set VITE_API_BASE_URL to your backend URL

# MySQL auth database (Namecheap cPanel)
DB_HOST=localhost
DB_NAME=fitypbvk_fityvid_auth
DB_USER=fitypbvk_fityvid_user
DB_PASSWORD=

# Auth — set a strong secret in production
JWT_SECRET=
JWT_EXPIRES_IN=7d
